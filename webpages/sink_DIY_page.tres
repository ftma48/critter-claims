[ext_resource type="Script" uid="uid://nhtt4y54fg51" path="res://scripts/WebPageData.gd" id="1_ogs1k"]

[resource]
script = ExtResource("1_ogs1k")
title = "Claim: Escape of water or oil"
content = "✅ What's covered:
Loss or damage:
• Caused by water leaking from or freezing in:
	• a fixed water, drainage or heating installation
	• a washing machine, dishwasher, water bed, fridge or freezer.
• Caused by oil either leaking from, or freezing in, a fixed oil-fired heating installation.


❌ What isn't covered:
Loss or damage:
• That has not been reported to the police
• While your home is unoccupied or unfurnished
• Caused by escape of water from guttering, rainwater and downpipes
• Caused by general lack of maintenance
• Caused by infill materials settling, swelling or shrinking due to an escape of water
• Caused by sulphate reacting with any materials your home is built from
"
call = true
dialogue = Array[String](["A leaky pipe... and my DIY fix made it so much worse.", "I'm not sure if accidental damage is covered on my policy.", "Wait... I do have accidental cover!", "Let me call and find out if this qualifies."])
metadata/_custom_type_script = "uid://nhtt4y54fg51"
