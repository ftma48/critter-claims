script = ExtResource("1_2hoh5")
title = "My Policy: Hastings Essential"
content = "✅ What's included:
• Storm or flood damage
• Escape of water or oil
• Theft 
• Vandalism or malicious damage
• Impact damage (e.g. falling trees)
• Fire, smoke, lightning, earthquake or explosions

❌ Not included:
• Home emergency cover
• Accidental damage
• Legal expenses cover

📋 Policy number: UNNY-00
Renewal date: 05 April 2026"
call = false
dialogue = Array[String](["Let me check what my Hastings Essential policy actually covers.", "I need to see if my situation qualifies before I make a claim.", "Here we go — let's see what's included..."])
